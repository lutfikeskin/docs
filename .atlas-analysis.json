  "keyFeatures": [
    "AI-powered PDF extraction of insurance policy data using Google Gemini",
    "Certificate of Insurance (COI) generation from ACORD 25 template",
    "Policy database with full CRUD, search, and customer management",
    "Renewal tracking with urgency buckets and email draft generation",
    "Side-by-side policy comparison and field-level diff view",
    "Duplicate detection and smart policy update previews",
    "Bulk COI generation with ZIP download",
    "Natural language query interface for policy data",
    "Daily API usage tracking and budget management",
    "Extraction confidence quality gates"
  ],
  "publicApiSurface": [
    "process_pdf(file_bytes, api_key, ...)",
    "PolicyService.get_dashboard_metrics()",
    "PolicyService.search_policies(term, limit, offset)",
    "PolicyService.count_policies(term)",
    "PolicyService.search_customers(term, orphan_filter, limit, offset)",
    "PolicyService.count_customers(term, orphan_filter)",
    "PolicyService.get_policy_by_id(policy_id)",
    "PolicyService.get_policy_by_number(policy_number)",
    "PolicyService.save_policy_from_extraction(extraction_result)",
    "PolicyService.detect_duplicate_for_extraction(extraction_result)",
    "PolicyService.preview_update_from_extraction(existing_policy, extraction_result)",
    "PolicyService.update_policy(policy, updated_data)",
    "PolicyService.delete_policy(policy)",
    "PolicyService.ask_your_data(user_query, api_key)",
    "PolicyService.get_renewal_buckets()",
    "PolicyService.get_expiring_policies(days)",
    "COIService.prepare_coi_data(...)",
    "COIGenerator.generate_coi(policy_data, holder_data, desc_font_size)",
    "UsageService.log_usage(...)",
    "UsageService.is_over_budget(...)",
    "UsageService.get_daily_usage()",
    "UsageService.get_todays_call_count()"
  ]
